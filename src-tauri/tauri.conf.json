{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "temp-converter",
  "version": "0.1.0",
  "identifier": "com.prodigy.tempconverter",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "python3 -c \"import http.server, mimetypes, os; os.chdir('src'); mimetypes.init(); mimetypes.add_type('text/css', '.css'); mimetypes.add_type('application/javascript', '.js'); http.server.test(HandlerClass=http.server.SimpleHTTPRequestHandler, port=5173)\"",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "Temperature Converter",
        "width": 460,
        "height": 580,
        "resizable": false,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
