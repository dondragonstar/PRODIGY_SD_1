{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "temp-converter",
  "version": "0.1.0",
  "identifier": "com.prodigy.tempconverter",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "title": "Temperature Converter",
        "width": 520,
        "height": 620,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
